# Copy this file to .env at the repo root and adjust as needed.
# All packages (api, worker, scheduler, db) load this same file.

DATABASE_URL="postgresql://jsp:jsp@localhost:5433/job_scheduler?schema=public"
REDIS_URL="redis://localhost:6380"

# API
API_PORT=4000
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
CORS_ORIGIN="http://localhost:5174"

# Worker
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=750
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKER_QUEUES="*"

# Scheduler / dispatcher
SCHEDULER_TICK_MS=1000

LOG_LEVEL="info"
